MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/forge
MONGO_DB=forge
HEVY_API_KEY=your_hevy_api_key
OURA_ACCESS_TOKEN=your_oura_token
WEBHOOK_SECRET=your_secret
HOST=0.0.0.0
PORT=8000

# Local preview without MongoDB Atlas
PREVIEW_MODE=true
PROGRAM_START=2026-05-19

# Data sync: pull Hevy + Oura every N minutes (as fast as you want)
SYNC_INTERVAL_MINUTES=15

# iMessage briefings: comma-separated hours (24h format, local time)
# Default: 7am morning briefing, 1pm and 7pm check-ins
BRIEFING_HOURS=7,13,19
IMESSAGE_RECIPIENT=+1XXXXXXXXXX

# Mobile dev (Expo web default ports)
CORS_ORIGINS=*
