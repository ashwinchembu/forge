MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/forge
MONGO_DB=forge
HEVY_API_KEY=your_hevy_api_key
OURA_ACCESS_TOKEN=your_oura_token
WEBHOOK_SECRET=your_secret
HOST=0.0.0.0
PORT=8000

# Local preview without MongoDB Atlas
PREVIEW_MODE=true
PROGRAM_START=2026-05-19

# Data sync: every N minutes
SYNC_INTERVAL_MINUTES=15

# Telegram bot (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Briefings at these hours (24h, local time)
BRIEFING_HOURS=7,13,19

# OpenAI (GPT-4o for food photo macro analysis)
OPENAI_API_KEY=

# Nutritionix (barcode + natural language food lookup)
# Sign up at https://developer.nutritionix.com (free tier: 1000 calls/day)
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

CORS_ORIGINS=*
